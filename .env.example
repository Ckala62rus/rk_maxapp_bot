BOT_TOKEN=REPLACE_ME

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app

DAX_MSSQL_HOST=your-mssql-host
DAX_MSSQL_PORT=1433
DAX_MSSQL_USER=sa
DAX_MSSQL_PASSWORD=your-password
DAX_MSSQL_DB=DAX
DAX_MSSQL_ENCRYPT=disable

LOG_LEVEL=debug
ENABLE_INITDATA_MOCK=true

PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin

GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin

# Docker logging driver runs on the *host* — use localhost + published Loki port (not hostname `loki`).
LOKI_URL=http://127.0.0.1:3100/loki/api/v1/push

# Порты nginx на хосте (сервис web). Если 80/443 заняты другими приложениями:
# WEB_HTTP_PORT=88
# WEB_HTTPS_PORT=8443
