# Dev image: app + Delve for remote debugging (GoLand Go Remote)
FROM golang:1.25-alpine AS builder

WORKDIR /build

RUN apk add --no-cache ca-certificates git

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -gcflags="all=-N -l" -o /app/server ./cmd/server

# Install Delve
RUN go install github.com/go-delve/delve/cmd/dlv@latest

# Runtime with Delve
FROM alpine:3.20

RUN apk add --no-cache ca-certificates

WORKDIR /app

COPY --from=builder /app/server .
COPY --from=builder /go/bin/dlv /usr/local/bin/
COPY docker/config.app.yml ./config.yml

EXPOSE 3000 40000

# Run under Delve; connect from GoLand via Go Remote localhost:40000
ENTRYPOINT ["dlv", "exec", "/app/server", "--headless", "--listen=:40000", "--api-version=2", "--accept-multiclient", "--"]
